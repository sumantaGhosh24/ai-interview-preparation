generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id
  name             String
  email            String
  emailVerified    Boolean   @default(false)
  image            String?
  twoFactorEnabled Boolean?  @default(false)
  role             String?
  banned           Boolean?  @default(false)
  banReason        String?
  banExpires       DateTime?
  favoriteNumber   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions   Session[]
  accounts   Account[]
  twofactors TwoFactor[]
  passkeys   Passkey[]

  topics        Topic[]
  answers       Answer[]
  jobs          QuestionGenerationJob[]
  performance   TopicPerformance[]
  learningPaths LearningPath[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String   @id
  secret      String
  backupCodes String
  verified    Boolean? @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model Passkey {
  id           String  @id
  name         String?
  publicKey    String
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  aaguid       String?

  createdAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Topic {
  id          String  @id @default(cuid())
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  questions    Question[]
  jobs         QuestionGenerationJob[]
  performance  TopicPerformance[]
  learningPath LearningPath[]

  @@index([userId])
  @@index([createdAt])
}

model Question {
  id         String     @id @default(cuid())
  question   String
  difficulty Difficulty
  isAI       Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  answers Answer[]

  @@index([topicId])
  @@index([difficulty])
  @@index([createdAt])
}

model Answer {
  id            String    @id @default(cuid())
  content       String
  status        JobStatus @default(PENDING)
  statusMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  evaluation AnswerEvaluation?

  @@index([userId])
  @@index([questionId])
  @@index([createdAt])
  @@index([status])
}

model QuestionGenerationJob {
  id                String    @id
  numberOfQuestions Int
  generatedCount    Int?
  status            JobStatus @default(PENDING)
  statusMessage     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([topicId])
  @@index([status])
  @@index([createdAt])
}

model AnswerEvaluation {
  id String @id @default(cuid())

  score       Int
  modelAnswer String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answerId String @unique
  answer   Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  mistakes     EvaluationMistake[]
  improvements EvaluationImprovement[]

  @@index([score])
  @@index([createdAt])
}

model EvaluationMistake {
  id      String @id @default(cuid())
  content String

  evaluationId String
  evaluation   AnswerEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
}

model EvaluationImprovement {
  id      String @id @default(cuid())
  content String

  evaluationId String
  evaluation   AnswerEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
}

model TopicPerformance {
  id           String @id @default(cuid())
  accuracy     Float
  avgScore     Float
  attemptCount Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId])
  @@index([topicId])
  @@index([accuracy])
  @@index([updatedAt])
}

model LearningPath {
  id String @id @default(cuid())

  title    String
  duration String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  phases LearningPathPhase[]

  @@index([userId])
  @@index([createdAt])
}

model LearningPathPhase {
  id             String       @id @default(cuid())
  learningPathId String
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  title    String
  duration String

  tasks LearningPathTask[]
}

model LearningPathTask {
  id      String            @id @default(cuid())
  phaseId String
  phase   LearningPathPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  task     String
  resource String?
}
